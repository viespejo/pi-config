#!/usr/bin/env sh
# PI external editor launcher.
#
# Intended usage:
#   EDITOR=/absolute/path/to/scripts/pi-editor-context
#   VISUAL=/absolute/path/to/scripts/pi-editor-context
#
# PI will invoke this script with the temp file path. This launcher delegates
# to the Node wrapper that injects local context and exports only the prompt.
#
# Optional diagnostics:
#   PI_EDITOR_DEBUG=1
# Debug log location:
#   ~/.local/state/pi-editor/debug.log

set -eu

SCRIPT_PATH="$0"
if command -v realpath >/dev/null 2>&1; then
  SCRIPT_PATH=$(realpath -- "$SCRIPT_PATH")
elif command -v readlink >/dev/null 2>&1; then
  LINK_TARGET=$(readlink -- "$SCRIPT_PATH" 2>/dev/null || true)
  if [ -n "${LINK_TARGET:-}" ]; then
    case "$LINK_TARGET" in
      /*) SCRIPT_PATH="$LINK_TARGET" ;;
      *) SCRIPT_PATH="$(dirname -- "$SCRIPT_PATH")/$LINK_TARGET" ;;
    esac
  fi
fi

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd)
REPO_ROOT=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)

exec node "$REPO_ROOT/scripts/pi-editor-context.mjs" "$@"
